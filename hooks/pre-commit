#!/bin/sh

# 1. Intentar aplicar el formato automáticamente
echo "🎨 Aplicando formateo de código..."
./mvnw spotless:apply

# 2. Solo añadir archivos que ya estaban en el index (evita basura)
git add -u

# 3. Validar que todo quedó perfecto
echo "🎨 Validando formateo de código..."
./mvnw spotless:check
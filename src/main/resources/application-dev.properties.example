spring.application.name=ecommerce
spring.output.ansi.enabled=always
server.port=9090
server.apiUrl=http://localhost:${server.port}
server.email=emailcomercial

spring.datasource.url=jdbc:postgresql://ip:port/ecommerce?options=-c%20timezone=UTC
spring.datasource.username=username
spring.datasource.password=password
spring.datasource.driver-class-name=org.postgresql.Driver

logging.level.org.hibernate.orm.connections.pooling=WARN
logging.level.com.zaxxer.hikari=INFO

spring.datasource.hikari.maximum-pool-size=10
spring.datasource.hikari.minimum-idle=5
spring.datasource.hikari.idle-timeout=300000
spring.datasource.hikari.connection-timeout=20000
spring.datasource.hikari.max-lifetime=1200000

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.highlight_sql=true
spring.jackson.time-zone=America/Argentina/Buenos_Aires
spring.jpa.properties.hibernate.jdbc.time_zone=America/Argentina/Buenos_Aires

springdoc.swagger-ui.path=/
springdoc.api-docs.path=/v3/api-docs
springdoc.show-actuator=true
springdoc.api-docs.groups.enabled=true
springdoc.swagger-ui.operationsSorter=method
springdoc.swagger-ui.tagsSorter=alpha
springdoc.swagger-ui.doc-expansion=none
springdoc.enable-default-api-docs=false
management.endpoints.web.exposure.include=*
management.endpoints.web.exposure.exclude = env, beans
management.endpoint.health.show-details=always
management.server.port=9091
management.endpoint.health.group.custom.include=diskSpace,ping,ssl,livenessState,readinessState
management.endpoint.health.show-components=always
management.metrics.tags.application=${spring.application.name}

##Desactivar metricas
management.health.db.enabled=false
management.health.discovery.enabled=false
management.health.discoveryComposite.enabled=false
management.health.discoveryClient.enabled=false
management.info.env.enabled=true
management.endpoint.health.probes.enabled=true
management.metrics.enable.jvm=true
management.metrics.enable.process=true
management.endpoint.prometheus.enabled=true
management.endpoint.shutdown.enabled=true
management.metrics.export.simple.enabled=false
management.endpoints.web.cors.allowed-origins=${server.apiUrl}
management.endpoints.web.cors.allowed-methods=GET,POST

info.app.name=Ecommerce API
info.app.version=1.0.0
info.app.author=Latam Shop